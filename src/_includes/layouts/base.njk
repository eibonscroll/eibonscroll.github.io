<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{% if title and title != "" %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="description" content="{{ description | default(site.description) }}"/>
  <meta name="author" content="{{ resume.basics.name }}"/>
  <link rel="icon" type="image/x-icon" href="/favicon.ico"/>
  <link rel="canonical" href="{{ site.url }}{{ page.url }}"/>
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ site.url }}/feed.xml"/>
  <meta property="og:title" content="{% if title and title != '' %}{{ title }}{% else %}{{ site.title }}{% endif %}"/>
  <meta property="og:description" content="{{ description | default(site.description) }}"/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content="{{ site.url }}{{ page.url }}"/>
  <meta name="twitter:card" content="summary"/>
  <meta name="twitter:title" content="{% if title and title != '' %}{{ title }}{% else %}{{ site.title }}{% endif %}"/>
  <meta name="twitter:description" content="{{ description | default(site.description) }}"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <nav class="site-nav" aria-label="Primary">
    <div class="site-nav__brand"><a href="/">{{ site.title }}</a></div>
    <div class="site-nav__links">
      <a href="/blog/">Blog</a>
      <a href="/projects/">Projects</a>
      <a href="/resume/">Resume</a>
      <a href="/about/">About</a>
    </div>
  </nav>
  <main id="main">
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <a href="{{ site.url }}/feed.xml">Atom feed</a>
    {% if resume.basics.profiles | length %}
    ·
    {% for p in resume.basics.profiles %}
    <a href="{{ p.url }}" rel="noopener">{{ p.network }}</a>
    {% if not loop.last %}·{% endif %}
    {% endfor %}
    {% endif %}
  </footer>
</body>
</html>
